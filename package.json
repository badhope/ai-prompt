{
  "name": "ai-prompt-framework",
  "version": "4.0.0",
  "description": "A simple and efficient AI Prompt Engineering Framework with Easy API, Template Engine, and Agent Support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./easy-api": {
      "types": "./dist/easy-api.d.ts",
      "import": "./dist/easy-api.js",
      "require": "./dist/easy-api.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build && npm run test && npm run lint && npm run typecheck",
    "example:developer": "ts-node examples/developer-usage.ts",
    "example:agent": "ts-node examples/ai-agent-usage.ts",
    "example:easy-api": "ts-node examples/easy-api-usage.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/user/ai-prompt.git"
  },
  "bugs": {
    "url": "https://github.com/user/ai-prompt/issues"
  },
  "homepage": "https://github.com/user/ai-prompt#readme",
  "keywords": [
    "ai",
    "prompt-engineering",
    "llm",
    "prompt-template",
    "prompt-management",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
