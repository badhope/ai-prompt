{
  "name": "ai-prompt-framework",
  "version": "4.0.0",
  "description": "Enterprise-grade Prompt Engineering Toolkit - Token Optimization, Chain-of-Thought, Function Calling, Lightweight Agent. Zero dependencies, bilingual support, production ready.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build && npm run test && npm run typecheck",
    "release": "npm run build && npm publish --access public",
    "release:jsr": "npx jsr publish",
    "release:jsr:dry": "npx jsr publish --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/badhope/ai-prompt.git"
  },
  "bugs": {
    "url": "https://github.com/badhope/ai-prompt/issues"
  },
  "homepage": "https://github.com/badhope/ai-prompt#readme",
  "keywords": [
    "ai",
    "llm",
    "prompt",
    "prompt-engineering",
    "prompt-optimization",
    "token-saving",
    "chain-of-thought",
    "cot",
    "function-calling",
    "tool-calling",
    "agent",
    "react-agent",
    "openai",
    "gpt",
    "claude",
    "prompt-template",
    "prompt-management",
    "i18n",
    "bilingual",
    "typescript",
    "zero-dependencies"
  ],
  "author": "ai-prompt",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jsr": {
    "name": "@ai/prompt-framework",
    "version": "4.0.0",
    "exports": "./src/index.ts"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/badhope"
  }
}
